// Font stack — dipakai oleh Docker image (fonts-noto-core, fonts-jetbrains-mono).
// Lokal di host bisa berbeda; Docker yang authoritative.

#let sans = "Noto Sans"
#let serif = "Noto Serif"
#let mono = "JetBrains Mono"

// Size tokens (existing reportlab values, port langsung)
#let size-cover-title = 18pt
#let size-cover-subtitle = 12pt
#let size-cover-info = 10pt
#let size-h1 = 14pt
#let size-h2 = 12pt
#let size-h3 = 10pt
#let size-body = 9pt
#let size-cell = 8pt
#let size-note = 8pt
